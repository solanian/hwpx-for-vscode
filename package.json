{
  "name": "vscode-hwpx",
  "displayName": "HWPX Viewer",
  "description": "Custom Editor for Hancom HWPX files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hwpx.showApiPort",
        "title": "HWPX: Show API Server Port"
      },
      {
        "command": "hwpx.copyApiHelp",
        "title": "HWPX: Copy API Help URL"
      }
    ],
    "customEditors": [
      {
        "viewType": "hwpx.preview",
        "displayName": "HWPX Viewer",
        "selector": [
          {
            "filenamePattern": "*.hwpx"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "test": "tsc -p tsconfig.test.json && node out-test/test/apiServer.test.js"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@types/jszip": "^3.4.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "fast-xml-parser": "^4.3.5"
  }
}
