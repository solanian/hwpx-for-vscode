{
  "name": "vscode-hwpx",
  "displayName": "HWPX Viewer",
  "description": "한컴 HWPX(한/글 2014+) 문서를 VS Code에서 열어보고, AI 에이전트가 HTTP API로 문서를 조작할 수 있는 확장입니다. (Beta)",
  "version": "0.0.1",
  "publisher": "solanian",
  "preview": true,
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/solanian/hwpx-for-vscode"
  },
  "homepage": "https://github.com/solanian/hwpx-for-vscode#readme",
  "bugs": {
    "url": "https://github.com/solanian/hwpx-for-vscode/issues"
  },
  "keywords": [
    "hwpx",
    "hwp",
    "hancom",
    "한글",
    "한컴",
    "viewer",
    "custom-editor",
    "owpml",
    "document"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hwpx.showApiPort",
        "title": "HWPX: Show API Server Port"
      },
      {
        "command": "hwpx.copyApiHelp",
        "title": "HWPX: Copy API Help URL"
      }
    ],
    "customEditors": [
      {
        "viewType": "hwpx.preview",
        "displayName": "HWPX Viewer",
        "selector": [
          {
            "filenamePattern": "*.hwpx"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "test": "tsc -p tsconfig.test.json && node out-test/test/apiServer.test.js"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@types/jszip": "^3.4.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "fast-xml-parser": "^4.3.5"
  }
}
