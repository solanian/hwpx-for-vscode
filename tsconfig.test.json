{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out-test",
        "rootDir": ".",
        "lib": ["ES2020"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "sourceMap": true
    },
    "include": ["src/**/*", "test/**/*"],
    "exclude": ["node_modules"]
}
